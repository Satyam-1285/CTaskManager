#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_TASKS 100
#define DESC_LEN 100

typedef struct {
    char description[DESC_LEN];
    int is_completed;
} Task;

Task tasks[MAX_TASKS];
int task_count = 0;

void saveTasks() {
    FILE *file = fopen("tasks.dat", "wb");
    if (file == NULL) return;
    fwrite(&task_count, sizeof(int), 1, file);
    fwrite(tasks, sizeof(Task), task_count, file);
    fclose(file);
}

void loadTasks() {
    FILE *file = fopen("tasks.dat", "rb");
    if (file == NULL) return;
    fread(&task_count, sizeof(int), 1, file);
    fread(tasks, sizeof(Task), task_count, file);
    fclose(file);
}

void addTask() {
    if (task_count >= MAX_TASKS) {
        printf("\n[!] Task list is full.\n");
        return;
    }
    printf("\nEnter task description: ");
    getchar(); // Clear buffer
    fgets(tasks[task_count].description, DESC_LEN, stdin);
    tasks[task_count].description[strcspn(tasks[task_count].description, "\n")] = 0;
    tasks[task_count].is_completed = 0;
    task_count++;
    saveTasks();
    printf("[+] Task added successfully!\n");
}

void listTasks() {
    if (task_count == 0) {
        printf("\n--- No tasks found ---\n");
        return;
    }
    printf("\n--- Current Tasks ---\n");
    for (int i = 0; i < task_count; i++) {
        printf("%d. [%s] %s\n", i + 1, tasks[i].is_completed ? "X" : " ", tasks[i].description);
    }
}

void completeTask() {
    int index;
    listTasks();
    if (task_count == 0) return;
    printf("\nEnter task number to mark as complete: ");
    scanf("%d", &index);
    if (index > 0 && index <= task_count) {
        tasks[index - 1].is_completed = 1;
        saveTasks();
        printf("[+] Task updated!\n");
    } else {
        printf("[!] Invalid task number.\n");
    }
}

int main() {
    int choice;
    loadTasks();

    while (1) {
        printf("\n--- CTask Manager ---\n");
        printf("1. View Tasks\n2. Add Task\n3. Mark Complete\n4. Exit\n");
        printf("Selection: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: listTasks(); break;
            case 2: addTask(); break;
            case 3: completeTask(); break;
            case 4: exit(0);
            default: printf("Invalid choice.\n");
        }
    }
    return 0;
}
